# Updated Automation Examples - Countdown Logic
# Accessories now count DOWN from 100% (new) to 0% (needs replacement)
# bearing in mind my x10 omni pro has an ID of amp96x0e33100080 to use the examples you would need to change all instances of amp96x0e33100080 to your actual ID.

# 1. Filter Replacement Alert (Critical - ≤10% remaining)
automation:
  - alias: "Robovac Filter Critical - Replace Now"
    description: "Critical alert when filter has ≤10% life remaining"
    trigger:
      - platform: numeric_state
        entity_id: sensor.amp96x0e33100080_filter_remaining  # Changed from _percentage to _remaining
        below: 11
        for:
          minutes: 5
    condition:
      - condition: template
        value_template: "{{ states('sensor.amp96x0e33100080_filter_remaining') != 'unknown' }}"
    action:
      - service: notify.mobile_app_your_phone
        data:
          title: "🔴 URGENT: Robovac Filter Critical"
          message: >
            Filter only has {{ states('sensor.amp96x0e33100080_filter_remaining') }}% life remaining!
            Replace immediately for optimal performance.
            ({{ state_attr('sensor.amp96x0e33100080_filter_remaining', 'hours_used') }}/{{ state_attr('sensor.amp96x0e33100080_filter_remaining', 'max_hours') }} hours used)
          data:
            tag: "robovac_filter_critical"
            actions:
              - action: "ORDER_FILTER"
                title: "Order Filter"

---

# 2. Any Accessory Low (≤20% remaining)
automation:
  - alias: "Robovac Accessory Low - Replace Soon"
    description: "Alert when any accessory has ≤20% life remaining"
    trigger:
      - platform: numeric_state
        entity_id:
          - sensor.amp96x0e33100080_filter_remaining
          - sensor.amp96x0e33100080_rolling_brush_remaining
          - sensor.amp96x0e33100080_side_brush_remaining
          - sensor.amp96x0e33100080_mop_cloth_remaining
          - sensor.amp96x0e33100080_sensors_remaining
          - sensor.amp96x0e33100080_brush_guard_remaining
        below: 21
        for:
          minutes: 10
    action:
      - service: notify.mobile_app_your_phone
        data:
          title: "🟠 Robovac Accessory Replacement Soon"
          message: >
            {{ trigger.to_state.attributes.friendly_name }} has {{ trigger.to_state.state }}% life remaining.
            Consider ordering a replacement soon.
            
            Time remaining: {{ state_attr(trigger.entity_id, 'hours_remaining') }} hours 
            ({{ state_attr(trigger.entity_id, 'days_remaining') }} days)

