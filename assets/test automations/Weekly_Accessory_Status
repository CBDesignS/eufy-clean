alias: Robovac Weekly Accessory Status
description: Weekly report of all accessory life remaining
triggers:
  - at: "09:00:00"
    trigger: time
conditions:
  - condition: time
    weekday:
      - sun
actions:
  - data:
      title: 🤖 Weekly Robovac Status Report
      message: >
        Accessory Life Remaining:

        🔧 Filter: {{ states('sensor.amp96x0e33100080_filter_remaining') }}% 🧽
        Side Brush: {{ states('sensor.amp96x0e33100080_side_brush_remaining')
        }}% 🌀 Main Brush: {{
        states('sensor.amp96x0e33100080_main_brush_remaining') }}% 🗑️ Dust Bag:
        {{ states('sensor.amp96x0e33100080_dustbag_remaining') }}%

        {% set critical_items = [] %} {% if
        states('sensor.amp96x0e33100080_filter_remaining') | int <= 20 %}
          {% set critical_items = critical_items + ['Filter'] %}
        {% endif %} {% if states('sensor.amp96x0e33100080_side_brush_remaining')
        | int <= 20 %}
          {% set critical_items = critical_items + ['Side Brush'] %}
        {% endif %} {% if states('sensor.amp96x0e33100080_main_brush_remaining')
        | int <= 20 %}
          {% set critical_items = critical_items + ['Main Brush'] %}
        {% endif %} {% if states('sensor.amp96x0e33100080_dustbag_remaining') |
        int <= 20 %}
          {% set critical_items = critical_items + ['Dust Bag'] %}
        {% endif %}

        {% if critical_items | length > 0 %} ⚠️ Items needing attention: {{
        critical_items | join(', ') }} {% else %} ✅ All accessories in good
        condition {% endif %}
      data:
        tag: robovac_weekly_status
    action: notify.mobile_app_your_phone
